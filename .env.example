# ──────────────────────────────────────────────────
# Groq
# ──────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL_ID=meta-llama/llama-4-scout-17b-16e-instruct

# ──────────────────────────────────────────────────
# Bedrock (bearer-token path, no access-key/secret needed)
# ──────────────────────────────────────────────────
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1

# Model ID used by both bedrock-bearer and bedrock-sdk providers
BEDROCK_MODEL_ID=

# ──────────────────────────────────────────────────
# Bedrock SDK (IAM credentials, required only for bedrock-sdk provider)
# ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ──────────────────────────────────────────────────
# AI Provider Switch
# Valid values: "groq" (default), "bedrock-bearer", "bedrock-sdk"
# ──────────────────────────────────────────────────
AI_PROVIDER=groq

# ──────────────────────────────────────────────────
# Supabase (persistence layer)
# ──────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ──────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────
PORT=3001

# Production CORS: set to the Amplify-hosted frontend URL to restrict origins.
# When unset, all origins are allowed (development mode).
FRONTEND_URL=
